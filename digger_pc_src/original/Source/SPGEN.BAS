97 '
98 ' ----------  Variable and Array Initialization
99 '
100 DEFINT A-Z
110 DIM SCREEN.IMAGE(31,31)  ' screen image array
120 DIM COLOR.0(10), COLOR.1(10), COLOR.2(10), COLOR.3(10), BACKGND(10)
130 DIM CURSOR.IMG(10)  ' cursor image
500 CURSOR.X = 0:CURSOR.Y = 0:NEW.CURSOR.X=0:NEW.CURSOR.Y=0  ' cursor position
505 FALSE=0:TRUE=-1
510 NEW.POS=FALSE:PIX.COLOR = 3  ' pixel color
520 CURSOR.ON=TRUE:CURSOR.BLINK=FALSE:NEW.COLOR=FALSE:PALETTE=1
530 TB$=CHR$(9)
540 SP$=SPACE$(15)
898 FOR N=1 TO 14:KEY(N) OFF:NEXT
900 ON KEY(1) GOSUB 10000:ON KEY(2) GOSUB 10500:ON KEY(3) GOSUB 11000
910 ON KEY(4) GOSUB 11500:ON KEY(5) GOSUB 12000:ON KEY(10) GOSUB 12500
920 ON KEY(11) GOSUB 13000:ON KEY(12) GOSUB 13500:ON KEY(13) GOSUB 14000
930 ON KEY(14) GOSUB 14500:ON KEY(9) GOSUB 15000:ON KEY(8) GOSUB 46000
940 ON KEY(7) GOSUB 50000:ON KEY(6) GOSUB 51000
996 '
997 ' ----------  Get Pixel Colors
998 '
999 '
1000 SCREEN 1:COLOR 0,1:CLS
1010 GET(0,0)-(3,3),COLOR.0  ' get color 0
1020 LINE(1,1)-(2,2),3,BF:GET(0,0)-(3,3),BACKGND  ' background
1030 LINE(0,0)-(3,3),1,BF:GET(0,0)-(3,3),COLOR.1  ' get color 1
1040 LINE(0,0)-(3,3),2,BF:GET(0,0)-(3,3),COLOR.2  ' get color 2
1050 LINE(0,0)-(3,3),3,BF:GET(0,0)-(3,3),COLOR.3  ' get color 3
1060 CLS:LINE(0,0)-(5,5),3,B:GET(0,0)-(5,5),CURSOR.IMG
1996 '
1997 ' ---------- Set up Screen
1998 '
1999 '
2000 CLS
2010 FOR X=0 TO 160 STEP 5:LINE(X+10,10)-(X+10,170),3:NEXT
2020 FOR Y=0 TO 160 STEP 5:LINE(10,Y+10)-(170,Y+10),3:NEXT
2030 LOCATE 1,9:PRINT "Sprite Generation Program"
2040 KEY(1) ON:KEY(2) ON:KEY(3) ON:KEY(4) ON:KEY(5) ON:KEY(8) ON:KEY(9) ON
2050 KEY(10) ON:KEY(11) ON:KEY(12) ON:KEY(13) ON:KEY(14) ON:KEY(7) ON
2055 KEY(6) ON
2060 LOCATE 13,23:PRINT "F1  - Black"
2070 LOCATE 14,23:PRINT "F2  - Cyan/Green"
2080 LOCATE 15,23:PRINT "F3  - Magenta/Red"
2090 LOCATE 16,23:PRINT "F4  - White/Brown"
2100 LOCATE 17,23:PRINT "F5  - Background"
2110 LOCATE 18,23:PRINT "F6  - Palette"
2120 LOCATE 19,23:PRINT "F7  - Exit"
2130 LOCATE 20,23:PRINT "F8  - Read File"
2140 LOCATE 21,23:PRINT "F9  - Clear"
2150 LOCATE 22,23:PRINT "F10 - Write File"
2997 '
2998 ' --------  Program Loop
2999 '
3000 GOSUB 20000  ' check for new cursor position
3010 GOSUB 22000  ' display cursor
3020 GOSUB 23000  ' check for new color
3025 X$=INKEY$
3030 GOTO 3000
9997 '
