9999 '
10000 NEW.COLOR=TRUE:PIX.COLOR=0
10400 RETURN
10497 '
10498 ' color
10499 '
10500 NEW.COLOR=TRUE:PIX.COLOR=1
10900 RETURN
10997 '
10998 ' color 2
10999 '
11000 NEW.COLOR=TRUE:PIX.COLOR=2
11400 RETURN
11497 '
11498 ' color 3
11499 '
11500 NEW.COLOR=TRUE:PIX.COLOR=3
11900 RETURN
11997 '
11998 ' background color
11999 '
12000 NEW.COLOR=TRUE:PIX.COLOR=4
12400 RETURN
12497 '
12498 ' save sprite arrays to disk
12499 '
12500 CURSOR.ON=FALSE:GOSUB 22000
12505 LOCATE 1,1:PRINT "                                     ";
12510 LOCATE 1,1:INPUT "WRITE Sprite Number (0 - 15) ",NUM$
12515 IF NUM$="" THEN 12545 ELSE IF VAL(NUM$)>15 OR VAL(NUM$)<0 THEN 12505
12520 LOCATE 1,1:PRINT "                                     ";
12530 LOCATE 1,1:PRINT "Saving Sprite to SPRITE";NUM$;".spr  ";
12540 GOSUB 30000  ' do routines
12545 CURSOR.ON=TRUE
12550 LOCATE 1,1:PRINT "        Sprite Generation Program    ";
12900 RETURN
12997 '
12998 ' move up
12999 '
13000 IF CURSOR.Y>0 THEN NEW.POS=TRUE:NEW.CURSOR.Y=CURSOR.Y-1
13400 RETURN
13497 '
13498 ' move left
13499 '
13500 IF CURSOR.X>0 THEN NEW.POS=TRUE:NEW.CURSOR.X=CURSOR.X-1
13900 RETURN
13997 '
13998 ' move right
13999 '
14000 IF CURSOR.X<31 THEN NEW.POS=TRUE:NEW.CURSOR.X=CURSOR.X+1
14400 RETURN
14497 '
14498 ' move down
14499 '
14500 IF CURSOR.Y<31 THEN NEW.POS=TRUE:NEW.CURSOR.Y=CURSOR.Y+1
14900 RETURN
14997 '
14998 ' ----------  clear screen
14999 '
15000 CURSOR.ON=FALSE:GOSUB 22000:LOCATE 1,1:PRINT SPACE$(38);
15001 LOCATE 1,1:INPUT "Clear Screen (y or n) ",A$
15002 IF A$="y" THEN 15004
15003 CURSOR.ON=TRUE:GOTO 15035
15004 LOCATE 1,1:PRINT "        Clearing Screen Buffer       ";
15005 PIX.COLOR=0
15010 FOR CURSOR.X=0 TO 31:FOR CURSOR.Y=0 TO 31
15020 IF SCREEN.IMAGE(CURSOR.X,CURSOR.Y) THEN NEW.COLOR=TRUE:GOSUB 23000
15023 NEXT:NEXT
15025 NEW.CURSOR.X=0:NEW.CURSOR.Y=0
15030 CURSOR.X=0:CURSOR.Y=0:CURSOR.ON=TRUE:GOSUB 22000
15035 LOCATE 1,1:PRINT "        Sprite Generation Program    ";
15040 RETURN
19997 '
19998 ' --------  check for new cursor position
19999 '
20000 IF NOT NEW.POS THEN RETURN
20003 IF NOT WID.DISPLAY THEN 20005
20004 WID.DISPLAY=FALSE:LOCATE 7,23:PRINT SP$:LOCATE 8,23:PRINT SP$
20005 NEW.POS=FALSE
20010 CURSOR.ON=FALSE:GOSUB 22000  ' shut off cursor
20020 CURSOR.X=NEW.CURSOR.X:CURSOR.Y=NEW.CURSOR.Y
20030 CURSOR.ON=TRUE  ' turn back on
20040 RETURN
21997 '
21998 ' ----------  Display Cursor
21999 '
22000 IF (NOT CURSOR.ON) AND (NOT CURSOR.BLINK) THEN RETURN
22010 IF NOT CURSOR.ON THEN 22110
22020 BLINK=BLINK+1
22030 IF BLINK<180 THEN RETURN ELSE BLINK=1
22110 CURSOR.BLINK=NOT CURSOR.BLINK
22120 CURSOR.X.ADD=CURSOR.X*5+10:CURSOR.Y.ADD=CURSOR.Y*5+10
22130 PUT(CURSOR.X.ADD,CURSOR.Y.ADD),CURSOR.IMG
22140 RETURN
22997 '
22998 ' ----------  check for color key pressed
22999 '
23000 IF NOT NEW.COLOR THEN RETURN
23005 NEW.COLOR=FALSE
23010 COLOR.X.ADD=CURSOR.X*5+11:COLOR.Y.ADD=CURSOR.Y*5+11
23020 ON PIX.COLOR+1 GOSUB 23100,23150,23200,23250,23300
23030 RETURN
23100 PUT(COLOR.X.ADD,COLOR.Y.ADD),COLOR.0,PSET
23105 SCREEN.IMAGE(CURSOR.X,CURSOR.Y)=0
23110 PSET(CURSOR.X+200,CURSOR.Y+10),0:RETURN
23150 PUT(COLOR.X.ADD,COLOR.Y.ADD),COLOR.1,PSET
23155 SCREEN.IMAGE(CURSOR.X,CURSOR.Y)=1
23160 PSET(CURSOR.X+200,CURSOR.Y+10),1:RETURN
23200 PUT(COLOR.X.ADD,COLOR.Y.ADD),COLOR.2,PSET
23205 SCREEN.IMAGE(CURSOR.X,CURSOR.Y)=2
23210 PSET(CURSOR.X+200,CURSOR.Y+10),2:RETURN
23250 PUT(COLOR.X.ADD,COLOR.Y.ADD),COLOR.3,PSET
23255 SCREEN.IMAGE(CURSOR.X,CURSOR.Y)=3
23260 PSET(CURSOR.X+200,CURSOR.Y+10),3:RETURN
23300 PUT(COLOR.X.ADD,COLOR.Y.ADD),BACKGND,PSET
23305 SCREEN.IMAGE(CURSOR.X,CURSOR.Y)=4
23310 PSET(CURSOR.X+200,CURSOR.Y+10),0:RETURN
29997 '
29998 ' ----------  Array Generation Routine
29999 '
30000 GOSUB 40000  ' open file for output
30005 GOSUB 45000  ' output screen buffer
30010 GOSUB 41000  ' initialize transfer
30015 IF BAD.IMAGE THEN BAD.IMAGE=FALSE:BEEP:FOR X=0 TO 30000:NEXT:RETURN
30020 GOSUB 42000  ' begin transfer
30022 GOSUB 44000  ' set up outline transfer
30025 GOSUB 43000  ' transfer outline image
30030 CLOSE
30040 LOCATE 7,23:PRINT "X Width - ";X.WIDTH;"  "
30050 LOCATE 8,23:PRINT "Y Width - ";Y.WIDTH;"  "
30055 WID.DISPLAY=TRUE
30060 RETURN
39997 '
39998 ' ----------  open file for output
39999 '
40000 OPEN "sprite"+NUM$+".spr" FOR OUTPUT AS 1
40020 RETURN
40997 '
40998 ' ----------  initialize transfer
40999 '
41000 PRINT #1,TB$;"char";TB$;"image_";NUM$;"[] = {";
41005 FOR X=0 TO 31:FOR Y=0 TO 31  ' begin loop to find first x pixel
41010   IF SCREEN.IMAGE(X,Y) THEN 41100  ' leave loop if found
41020 NEXT:NEXT
41030 CLOSE:LOCATE 1,1:PRINT "        NO IMAGE DEFINED             ";
41040 BAD.IMAGE=TRUE:RETURN
41099 '
41100 IMAGE.X.START=X  ' get x starting point
41110 FOR Y=0 TO 31:FOR X=0 TO 31  ' begin loop to find first y pixel
41120   IF SCREEN.IMAGE(X,Y) THEN 41200  ' leave loop if found
41130 NEXT:NEXT
41199 '
41200 IMAGE.Y.START=Y  ' get y starting point
41210 FOR X=31 TO 0 STEP -1:FOR Y=0 TO 31  ' loop to find end x pixel
41220   IF SCREEN.IMAGE(X,Y) THEN 41300  ' leave loop if found
41230 NEXT:NEXT
41299 '
41300 IMAGE.X.END=X  ' get x ending point
41310 FOR Y=31 TO 0 STEP -1:FOR X=0 TO 31  ' loop to find end y pixel
41320   IF SCREEN.IMAGE(X,Y) THEN 41400  ' leave loop if found
41330 NEXT:NEXT
41399 '
41400 IMAGE.Y.END=Y  ' get y ending point
41410 X.WIDTH=(IMAGE.X.END-IMAGE.X.START)\4+1  ' x width of sprite
41420 Y.WIDTH=IMAGE.Y.END-IMAGE.Y.START+1      ' y width of sprite
41430 RETURN
41997 '
41998 ' ----------  Transfer Image to disk
41999 '
42000 FOR Y=IMAGE.Y.START TO IMAGE.Y.END  ' loop number of y image lines
42005 PRINT #1,"":PRINT #1,TB$;TB$;TB$;
42010   FOR X=IMAGE.X.START TO IMAGE.X.START+(X.WIDTH*4)-1 STEP 4
42020     IMAGE.BYTE=0
42030     XP=X:GOSUB 42500  ' get pixel color
42040     IMAGE.BYTE=IMAGE.BYTE OR (PCOLOR*64)  ' shift up 3 pixels
42050     XP=X+1:GOSUB 42500
42060     IMAGE.BYTE=IMAGE.BYTE OR (PCOLOR*16)  ' shift up 2 pixels
42070     XP=X+2:GOSUB 42500
42080     IMAGE.BYTE=IMAGE.BYTE OR (PCOLOR*4)   ' shift up 1 pixel
42090     XP=X+3:GOSUB 42500
42100     IMAGE.BYTE=IMAGE.BYTE OR PCOLOR       ' dont shift
42110     PRINT #1,USING "###";IMAGE.BYTE;:PRINT #1,",";  ' send out to disk
42120   NEXT
42130 NEXT
42140 PRINT #1,"0";TB$;"};"  ' send out closing quote
42150 RETURN
42497 '
42498 ' ----------  read screen array pixel
42499 '
42500 IF SCREEN.IMAGE(XP,Y)=4 THEN PCOLOR=0 ELSE PCOLOR=SCREEN.IMAGE(XP,Y)
42510 RETURN
42997 '
42998 ' ----------  output outline array
42999 '
43000 FOR Y=IMAGE.Y.START TO IMAGE.Y.END  ' loop number of y image lines
43005 PRINT #1,"":PRINT #1,TB$;TB$;TB$;
43010   FOR X=IMAGE.X.START TO IMAGE.X.START+(X.WIDTH*4)-1 STEP 4
43020     IMAGE.BYTE=0
43030     XP=X:GOSUB 43500  ' get pixel color
43040     IMAGE.BYTE=IMAGE.BYTE OR (PCOLOR*64)  ' shift up 3 pixels
43050     XP=X+1:GOSUB 43500
43060     IMAGE.BYTE=IMAGE.BYTE OR (PCOLOR*16)  ' shift up 2 pixels
43070     XP=X+2:GOSUB 43500
43080     IMAGE.BYTE=IMAGE.BYTE OR (PCOLOR*4)   ' shift up 1 pixel
43090     XP=X+3:GOSUB 43500
43100     IMAGE.BYTE=IMAGE.BYTE OR PCOLOR       ' dont shift
43110     PRINT #1,USING "###";IMAGE.BYTE;:PRINT #1,",";  ' send out to disk
43120   NEXT
43130 NEXT
43140 PRINT #1,"0";TB$;"};"  ' send out closing quote
43150 PRINT #1,""
43160 PRINT #1,TB$;"char";TB$;"bkgnd_";NUM$;"[";X.WIDTH*Y.WIDTH;"];"
43170 PRINT #1,""
43180 PRINT #1,"#define X_WID_";NUM$;X.WIDTH
43190 PRINT #1,"#define Y_WID_";NUM$;Y.WIDTH
43200 RETURN
43497 '
43498 ' ----------  read image byte
43499 '
43500 IF SCREEN.IMAGE(XP,Y)=4 THEN PCOLOR=3 ELSE PCOLOR=0
43510 RETURN
43997 '
43998 ' ---------- output outline header
43999 '
44000 PRINT #1,"":PRINT #1,""
44010 PRINT #1,TB$;"char";TB$;"outln_";NUM$;"[] = {";
44020 RETURN
44997 '
44998 ' ----------  output screen.image buffer
44999 '
45000 PRINT #1,"/*"
45010 FOR Y=0 TO 31
45020   FOR X=0 TO 31
45030     PRINT #1,SCREEN.IMAGE(X,Y);
45040   NEXT
45050   PRINT #1,""
45060 NEXT
45070 PRINT #1,"*/"
45080 RETURN
45997 '
45998 ' ---------- read image file
45999 '
46000 CURSOR.ON=FALSE:GOSUB 22000
46003 LOCATE 1,1:PRINT SPACE$(38)
46005 LOCATE 1,1:INPUT "READ Sprite Number (0 - 15) ",NUM$
46010 IF NUM$="" THEN 46100 ELSE IF VAL(NUM$)>15 OR VAL(NUM$)<0 THEN 46003
46020 LOCATE 1,1:PRINT "                                     ";
46030 LOCATE 1,1:PRINT "      Reading File SPRITE";NUM$;".spr  ";
46040 GOSUB 46200
46100 CURSOR.ON=TRUE
46110 LOCATE 1,1:PRINT "        Sprite Generation Program    ";
46120 RETURN
46197 '
46198 ' ----------  read in file
46199 '
46200 OPEN "sprite"+NUM$+".spr" FOR INPUT AS 1
46210 INPUT #1,A$  ' read /*
46215 FOR CURSOR.Y=0 TO 31:FOR CURSOR.X=0 TO 31
46220   INPUT #1,SCREEN.IMAGE(CURSOR.X,CURSOR.Y)
46230   NEW.COLOR=TRUE:PIX.COLOR=SCREEN.IMAGE(CURSOR.X,CURSOR.Y):GOSUB 23000
46240 NEXT:NEXT
46250 CLOSE
46270 CURSOR.X=0:CURSOR.Y=0:NEW.CURSOR.X=0:NEW.CURSOR.Y=0
46280 RETURN
